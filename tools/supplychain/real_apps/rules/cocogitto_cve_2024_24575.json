[
  {
    "cve": "CVE-2024-24575",
    "package": "libgit2",
    "version_range": "<1.7.2",
    "description": "libgit2 revparse 相关触发路径（cocogitto）。",
    "match": {
      "crates": ["git2", "libgit2-sys"]
    },
    "symbols": ["git_revparse_single"],
    "rust_sinks": [
      { "path": "git2::Repository::revparse_single" },
      { "path": "cocogitto::CocoGitto::get_changelog_at_tag" },
      { "path": "cocogitto::CocoGitto::get_changelog" },
      { "path": "cocogitto::CocoGitto::check_and_edit" },
      { "path": "cocogitto::CocoGitto::check" }
    ],
    "input_predicate": {
      "class": "crafted_revspec",
      "strategy": "assume_if_not_explicit"
    },
    "must_flow": [
      "Option<String>.as_deref -> revparse_single.arg1",
      "pattern -> revparse_single.arg1",
      "at -> revparse_single.arg1"
    ]
  }
]
